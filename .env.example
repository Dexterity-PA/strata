# Resend API key for contact form delivery (server-side only — never expose
# to the client). Create one at https://resend.com/api-keys.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend audience the footer newsletter signup subscribes to (server-side
# only). Resend now calls audiences "Segments" — the id still comes from
# GET https://api.resend.com/audiences.
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
